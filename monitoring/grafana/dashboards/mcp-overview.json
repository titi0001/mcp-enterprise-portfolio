{
  "title": "Retail MCP Overview",
  "uid": "retail-mcp-overview",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request rate",
      "id": 1,
      "targets": [{"expr": "sum by (operation) (rate(retail_mcp_requests_total[5m]))"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "p95 latency",
      "id": 2,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, operation) (rate(retail_mcp_request_duration_seconds_bucket[5m])))"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "stat",
      "title": "In-flight requests",
      "id": 3,
      "targets": [{"expr": "retail_mcp_in_flight_requests"}],
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8}
    },
    {
      "type": "stat",
      "title": "Cache hit ratio",
      "id": 4,
      "targets": [{"expr": "sum(rate(retail_mcp_cache_total{outcome=\"hit\"}[5m])) / clamp_min(sum(rate(retail_mcp_cache_total[5m])), 0.001)"}],
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8}
    },
    {
      "type": "stat",
      "title": "Dependency health",
      "id": 5,
      "targets": [{"expr": "retail_mcp_dependency_health"}],
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8}
    }
  ]
}
